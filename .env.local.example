# Copy this file to `.env.local` and fill in only the providers you want to use.

# Groq proxy
GROQ_API_KEY=your_groq_api_key
APP_HOST=127.0.0.1
APP_PORT=18010
GROQ_TTS_DEFAULT_MODEL=canopylabs/orpheus-v1-english
GROQ_TTS_DEFAULT_VOICE=daniel
GROQ_TTS_DEFAULT_RESPONSE_FORMAT=wav

# Gradium
GRADIUM_API_KEY=your_gradium_api_key
GRADIUM_BASE_URL=https://api.gradium.ai/api

# YourVoic
YOURVOIC_API_KEY=your_yourvoic_api_key
YOURVOIC_BASE_URL=https://yourvoic.com/api/v1

# Azure Speech
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=germanywestcentral
# Optional: use endpoint instead of region
# AZURE_SPEECH_ENDPOINT=https://germanywestcentral.api.cognitive.microsoft.com/

# Google Cloud TTS
# Either set a service-account JSON path:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# Or authenticate with gcloud application-default login.
